# ====================================================================
# Virtual Environments
# ====================================================================
venv/
.venv/
env/
ENV/


# ====================================================================
# Data and Logs (Keep the folder structure via .gitkeep, ignore contents)
# ====================================================================
# Instead of data/*, we explicitly ignore the specific subfolders
# that contain the massive files.
data/raw/
data/results/primary_ablation.csv
data/results/secondary_ablation.csv

# Ensure individual massive files anywhere else are blocked
*.csv
*.parquet

# --- EXCEPTIONS: runtime CSVs the Streamlit app must load ---
# These are small (<3 MB) and required at app startup / in the live demo.
# covid_surveillance_loinc.csv is a license-compliant LOINC subset (code +
# long common name retained); see LOINC_short_license.txt.
!data/processed/covid_surveillance_loinc.csv
!data/processed/elr_simulated.csv
!data/results/test_filter_ablation.csv

# --- EXCEPTIONS: Force Git to look inside the summary folder ---
!data/results/summary/
!data/results/summary/*

# Target logs specifically
logs/*
!logs/.gitkeep

# ====================================================================
# Archives (Completely omit 'archive' folders anywhere in the project)
# ====================================================================
**/archive/

# ====================================================================
# Jupyter Notebooks Artifacts
# ====================================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ====================================================================
# Python & OS Artifacts
# ====================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.DS_Store
Thumbs.db

# ====================================================================
# IDEs and Local Configurations
# ====================================================================
.vscode/
.idea/
.env